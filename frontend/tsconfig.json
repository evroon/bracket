{
  "compilerOptions": {
    "baseUrl": "src",
    "paths": {
      "@*": ["*"],
      "@components/*": ["components/*"],
      "@pages/*": ["pages/*"],
      "@openapi/*": ["openapi/*"],
    },
    "target": "es6",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true
  },
  "include": [ "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
